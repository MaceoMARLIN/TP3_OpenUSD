    def Scope "_materials"
    {
        def Material "standardSurface2SG"
        {
            token outputs:surface.connect = </root/_materials/standardSurface2SG/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "standardSurface2SG"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/standardSurface2SG/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic.connect = </root/_materials/standardSurface2SG/Image_Texture_001.outputs:r>
                float inputs:opacity = 1
                float inputs:roughness.connect = </root/_materials/standardSurface2SG/Image_Texture_002.outputs:r>
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface2SG_baseColor.jpg@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/standardSurface2SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "UV_Map"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "Image_Texture_001"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface2SG_metallicRoughness_metal_scale0.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/standardSurface2SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }

            def Shader "Image_Texture_002"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface2SG_metallicRoughness_rough.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/standardSurface2SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }
        }

        def Material "standardSurface3SG"
        {
            token outputs:surface.connect = </root/_materials/standardSurface3SG/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "standardSurface3SG"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/standardSurface3SG/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor.connect = </root/_materials/standardSurface3SG/Image_Texture_001.outputs:rgb>
                float inputs:ior = 1.5
                float inputs:metallic.connect = </root/_materials/standardSurface3SG/Image_Texture_002.outputs:r>
                float inputs:opacity = 1
                float inputs:roughness.connect = </root/_materials/standardSurface3SG/Image_Texture_003.outputs:r>
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface3SG_baseColor.jpg@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/standardSurface3SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "UV_Map"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "Image_Texture_002"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface3SG_metallicRoughness_metal_scale0.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/standardSurface3SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }

            def Shader "Image_Texture_003"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/standardSurface3SG_metallicRoughness_rough.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/standardSurface3SG/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
