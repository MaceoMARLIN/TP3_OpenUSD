    def Scope "_materials"
    {
        def Material "Rock02Shader"
        {
            token outputs:surface.connect = </root/_materials/Rock02Shader/Principled_BSDF.outputs:surface>
            custom string userProperties:blender:data_name = "Rock02Shader"

            def Shader "Principled_BSDF"
            {
                uniform token info:id = "UsdPreviewSurface"
                float inputs:clearcoat = 0
                float inputs:clearcoatRoughness = 0.03
                color3f inputs:diffuseColor.connect = </root/_materials/Rock02Shader/Image_Texture.outputs:rgb>
                color3f inputs:emissiveColor = (0, 0, 0)
                float inputs:ior = 1.5
                float inputs:metallic.connect = </root/_materials/Rock02Shader/Image_Texture_001.outputs:r>
                normal3f inputs:normal.connect = </root/_materials/Rock02Shader/Image_Texture_003.outputs:rgb>
                float inputs:opacity = 1
                float inputs:roughness.connect = </root/_materials/Rock02Shader/Image_Texture_002.outputs:r>
                float inputs:specular = 0.5
                token outputs:surface
            }

            def Shader "Image_Texture"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Rock02Shader_baseColor.jpg@
                token inputs:sourceColorSpace = "sRGB"
                float2 inputs:st.connect = </root/_materials/Rock02Shader/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }

            def Shader "UV_Map"
            {
                uniform token info:id = "UsdPrimvarReader_float2"
                string inputs:varname = "st"
                float2 outputs:result
            }

            def Shader "Image_Texture_001"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Rock02Shader_metallicRoughness_metal_scale0.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/Rock02Shader/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }

            def Shader "Image_Texture_002"
            {
                uniform token info:id = "UsdUVTexture"
                asset inputs:file = @./textures/Rock02Shader_metallicRoughness_rough.jpg@
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/Rock02Shader/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float outputs:r
            }

            def Shader "Image_Texture_003"
            {
                uniform token info:id = "UsdUVTexture"
                float4 inputs:bias = (-1, -1, -1, -1)
                asset inputs:file = @./textures/Rock02Shader_normal.jpg@
                float4 inputs:scale = (2, 2, 2, 2)
                token inputs:sourceColorSpace = "raw"
                float2 inputs:st.connect = </root/_materials/Rock02Shader/UV_Map.outputs:result>
                token inputs:wrapS = "repeat"
                token inputs:wrapT = "repeat"
                float3 outputs:rgb
            }
        }
    }

    def DomeLight "env_light"
    {
        float inputs:intensity = 1
        asset inputs:texture:file = @./textures/color_0C0C0C.exr@
    }
}

